{
  "name": "thierry_next",
  "homepage": "https://thierrycasters.fr",
  "version": "2.0.1",
  "description": "Thierry Casters portfolio",
  "repository": "thierry_v2",
  "keywords": [],
  "author": "Marion Casters",
  "license": "ISC",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node server.js",
    "build": "next build --webpack",
    "start": "cross-env NODE_ENV=production node server.js",
    "lint": "next lint",
    "generate": "dotenv -e .env.local -- npx prisma generate",
    "prisma:push": "dotenv -e .env.local -- prisma db push",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:format": "prisma format",
    "deploy-build": "prisma generate && dotenv -e .env.local -- prisma migrate deploy && next build"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "cross-env": "^10.1.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "jose": "^6.2.2",
    "next": "16.2.1",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-image-file-resizer": "^0.4.8",
    "sharp": "^0.34.3",
    "styled-jsx": "^5.1.7",
    "yet-another-react-lightbox": "^3.29.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
